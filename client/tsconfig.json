{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* Strict checks */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* Emit */
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    /* Path aliases (must match vite.config / vitest.config) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@tests/*": ["tests/*"],
      "@peek/shared-types": ["../shared/types/index.ts"],
      "@peek/shared-types/*": ["../shared/types/*"]
    }
  },
  "include": ["src", "tests"],
  "references": [{ "path": "../shared" }]
}
